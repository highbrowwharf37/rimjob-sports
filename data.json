{"teams":[],"players":[],"updated":""}
```

Click **"Commit changes"**.

### Step 2 — Create the GitHub Action

Click **"Add file" → "Create new file"**, name it exactly:
```
.github/workflows/fetch-data.yml
name: Fetch CBB Data
on:
  schedule:
    - cron: '0 8 * * *'  # runs every day at 8am
  workflow_dispatch:       # lets you run it manually too

jobs:
  fetch:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Fetch Barttorvik data
        run: |
          curl -o teams_raw.json "https://barttorvik.com/2026_team_results.json" \
            -H "User-Agent: Mozilla/5.0"
          curl -o players_raw.json "https://barttorvik.com/playerstat.php?year=2026&json=1&minmin=150" \
            -H "User-Agent: Mozilla/5.0"
          python3 -c "
import json, datetime
with open('teams_raw.json') as f: teams = json.load(f)
with open('players_raw.json') as f: players = json.load(f)
out = {'teams': teams, 'players': players, 'updated': datetime.datetime.utcnow().isoformat()}
with open('data.json','w') as f: json.dump(out, f)
"
      - name: Commit data
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add data.json
          git commit -m "Update CBB data" || echo "No changes"
          git push
